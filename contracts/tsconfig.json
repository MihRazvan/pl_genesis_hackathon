{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "hardhat"]
  },
  "include": ["./hardhat.config.ts", "./deploy/**/*.ts", "./test/**/*.ts", "./scripts/**/*.ts"]
}
