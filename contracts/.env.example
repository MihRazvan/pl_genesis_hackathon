# Optional: override if you want a specific provider
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Required for deploying to Sepolia
# Format: 64 hex chars prefixed with 0x
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: wallet allowed to call incrementQueryCountForUserBucket.
# If omitted, deployer address is used.
PROXY_LOGGER_ADDRESS=0xYOUR_PROXY_LOGGER_ADDRESS
