{
  "name": "cloakline",
  "version": "0.1.0",
  "private": true,
  "description": "Cloakline: privacy-preserving Ethereum RPC for unlinkability and write-only encrypted logging",
  "type": "module",
  "scripts": {
    "dev": "tsx watch proxy/src/server.ts",
    "start": "tsx proxy/src/server.ts",
    "site:dev": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "site:preview": "vite preview --config site/vite.config.ts",
    "site:typecheck": "tsc -p site/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo:check": "bash scripts/demo-check.sh",
    "demo:before-after": "bash demo/run-before-after.sh",
    "state:contract": "tsx scripts/check-contract-state.ts",
    "contracts:install": "pnpm --dir contracts install",
    "contracts:compile": "pnpm --dir contracts compile",
    "contracts:test": "pnpm --dir contracts test",
    "contracts:deploy:hardhat": "pnpm --dir contracts deploy:hardhat",
    "contracts:deploy:sepolia": "pnpm --dir contracts deploy:sepolia"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/space-grotesk": "^5.2.10",
    "ethers": "^6.16.0",
    "fastify": "^5.6.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
